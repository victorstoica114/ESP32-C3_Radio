,\r\npower_profiler/radio_power_profiler\\profiles.json:58:    \"notes\": [\"AT+PWR controls the CC1101 PATABLE drive setting, not a separate external-PA gain.\"]\r\npower_profiler/radio_power_profiler\\profiles.json:71:      {\"name\": \"cc1101_drive_dbm\", \"label\": \"CC1101 drive (dBm)\", \"command\": \"AT+PWR={value}\", \"values\": [-30, 0, 10]},\r\npower_profiler/radio_power_profiler\\profiles.json:76:    \"notes\": [\"AT+PWR controls the CC1101 PATABLE drive setting, not a separate external-PA gain.\"]\r\npower_profiler/radio_power_profiler\\profiles.json:89:      {\"name\": \"cc1101_drive_dbm\", \"label\": \"CC1101 drive (dBm)\", \"command\": \"AT+PWR={value}\", \"values\": [-30, 0, 10]},\r\npower_profiler/radio_power_profiler\\profiles.json:94:    \"notes\": [\"The module contains an external PA/LNA; AT+PWR still changes only the exposed CC1101 drive preset.\"]\r\npower_profiler/radio_power_profiler\\profiles.py:143:        inter_run_commands=profile.inter_run_commands,\r\npower_profiler/radio_power_profiler\\profiles.py:144:        power_cycle_between_runs=profile.power_cycle_between_runs,\r\npower_profiler/radio_power_profiler\\profiles.py:145:        power_cycle_min_airtime_s=profile.power_cycle_min_airtime_s,\r\npower_profiler/radio_power_profiler\\profiles.py:146:        power_cycle_off_s=profile.power_cycle_off_s,\r\npower_profiler/radio_power_profiler\\profiles.py:93:        inter_run_commands=tuple(raw.get(\"inter_run_commands\", [])),\r\npower_profiler/radio_power_profiler\\profiles.py:94:        power_cycle_between_runs=bool(raw.get(\"power_cycle_between_runs\", False)),\r\npower_profiler/radio_power_profiler\\profiles.py:95:        power_cycle_min_airtime_s=float(raw.get(\"power_cycle_min_airtime_s\", 0.0)),\r\npower_profiler/radio_power_profiler\\profiles.py:96:        power_cycle_off_s=float(raw.get(\"power_cycle_off_s\", 1.0)),\r\npower_profiler/radio_power_profiler\\runner.py:149:def _should_reset_between_runs(profile: Profile, case: TestCase) -> bool:\r\npower_profiler/radio_power_profiler\\runner.py:150:    \"\"\"Return whether this case needs the profile's queue-clearing reset.\"\"\"\r\npower_profiler/radio_power_profiler\\runner.py:151:    if not profile.inter_run_commands:\r\npower_profiler/radio_power_profiler\\runner.py:153:    if not profile.power_cycle_between_runs:\r\npower_profiler/radio_power_profiler\\runner.py:155:    return case.estimated_airtime_s >= profile.power_cycle_min_airtime_s\r\npower_profiler/radio_power_profiler\\runner.py:158:def _restore_after_reset(\r\npower_profiler/radio_power_profiler\\runner.py:164:    \"\"\"Reapply the complete modem configuration after a reset.\"\"\"\r\npower_profiler/radio_power_profiler\\runner.py:468:                if _should_reset_between_runs(profile, case):\r\npower_profiler/radio_power_profiler\\runner.py:469:                    if profile.power_cycle_between_runs:\r\npower_profiler/radio_power_profiler\\runner.py:471:                        time.sleep(profile.power_cycle_off_s)\r\npower_profiler/radio_power_profiler\\runner.py:476:                        radio.configure(profile.inter_run_commands)\r\npower_profiler/radio_power_profiler\\runner.py:477:                    _restore_after_reset(\r\npower_profiler/radio_power_profiler\\runner.py:484:                        peer.configure(profile.inter_run_commands)\r\npower_profiler/radio_power_profiler\\runner.py:485:                        _restore_after_reset(\r\npower_profiler/radio_power_profiler\\serial_radio.py:60:        # Opening an ESP32-C3 USB CDC port can reset the controller.  Wait for\r\npower_profiler/radio_power_profiler\\web_app.py:428:                f\"{_number(config.continuous_duration_s)} s/power level\"\r\npower_profiler/radio_power_profiler\\web_app.py:448:                    f\"{_number(config.continuous_duration_s)} s/power level\"\r\n","exit_code":0,"status":"completed"}}
