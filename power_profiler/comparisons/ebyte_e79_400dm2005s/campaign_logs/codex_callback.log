24:     tx_rows: list[dict[str, Any]],\r\n 125:     rx_rows: list[dict[str, Any]],\r\n 126:     repetitions: int,\r\n 127: ) -> tuple[list[int], list[float], list[tuple[str, float, str]], float, str, int]:\r\n 128:     module = str(tx_rows[0][\"module\"])\r\n 129:     if any(row[\"module\"] != module for row in tx_rows + rx_rows):\r\n 130:         raise ValueError(\"TX and RX data refer to different modules\")\r\n 408: def _read_loss_rows(result_dirs: list[Path]) -> list[dict[str, Any]]:\r\n 409:     rows: list[dict[str, Any]] = []\r\n 410:     for result_dir in result_dirs:\r\n 411:         metadata = json.loads((result_dir / \"metadata.json\").read_text(encoding=\"utf-8\"))\r\n 412:         if metadata.get(\"measurement_direction\") != \"rx\":\r\n 413:             raise ValueError(f\"Not an RX continuous result: {result_dir}\")\r\n 414:         with (result_dir / \"summary.csv\").open(encoding=\"utf-8\", newline=\"\") as stream:\r\n 415:             for raw in csv.DictReader(stream):\r\n 416:                 transmitted = int(float(raw[\"frames_transmitted\"]))\r\n 417:                 received = int(raw[\"frames_received\"])\r\n 418:                 loss = float(raw[\"frame_loss_percent\"])\r\n 419:                 row = {\r\n 420:                     \"bit_rate_kbps\": float(raw[\"bit_rate_kbps\"]),\r\n 421:                     \"rf_profile\": raw.get(\"rf_profile\", \"\"),\r\n 422:                     \"tx_power_dbm\": float(raw[\"tx_power_dbm\"]),\r\n 423:                     \"frames_transmitted\": transmitted,\r\n 424:                     \"frames_received\": received,\r\n 425:                     \"frames_lost\": transmitted - received,\r\n 426:                     \"frame_loss_percent\": loss,\r\n 427:                     \"delivery_percent\": 100.0 - loss,\r\n 428:                     \"requested_duration_s\": float(raw[\"requested_duration_s\"]),\r\n 429:                     \"frame_bytes\": int(raw[\"frame_bytes\"]),\r\n 430:                     \"inter