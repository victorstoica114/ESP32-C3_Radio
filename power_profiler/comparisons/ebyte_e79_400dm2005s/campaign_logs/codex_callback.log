continuous_report.read_session(\r\n 634:         continuous_rx\r\n 635:     )\r\n 636:     continuous_report.validate(\r\n 637:         tx_continuous_rows,\r\n 638:         tx_continuous_metadata,\r\n 639:         rx_continuous_rows,\r\n 640:         rx_continuous_metadata,\r\n 641:     )\r\n 642:     continuous_base = base.with_name(base.name + \"_continuous\")\r\n 643:     continuous_rows = sorted(\r\n 644:         tx_continuous_rows + rx_continuous_rows,\r\n 645:         key=lambda row: (row[\"measurement_direction\"], row[\"tx_power_dbm\"]),\r\n 646:     )\r\n 647:     continuous_report.write_csv(continuous_base.with_suffix(\".csv\"), continuous_rows)\r\n 648:     continuous_report.write_xlsx(\r\n 649:         continuous_base.with_suffix(\".xlsx\"),\r\n 650:         tx_continuous_rows,\r\n 651:         rx_continuous_rows,\r\n 652:         tx_continuous_metadata,\r\n 653:         rx_continuous_metadata,\r\n 654:     )\r\n 655:     continuous_report.write_power_tex(\r\n 656:         continuous_base.with_name(continuous_base.name + \"_average_power\").with_suffix(\".tex\"),\r\n 657:         tx_continuous_rows,\r\n 658:         rx_continuous_rows,\r\n 659:         module,\r\n 660:     )\r\n 661:     continuous_report.write_delivery_tex(\r\n 662:         continuous_base.with_name(continuous_base.name + \"_rx_delivery\").with_suffix(\".tex\"),\r\n 663:         rx_continuous_rows,\r\n 664:         module,\r\n 665:     )\r\n 666:     loss_rows = _read_loss_rows(loss_dirs)\r\n 667:     _write_loss_reports(\r\n 668:         base.with_name(base.name + \"_loss_vs_rate\"), loss_rows, module\r\n 669:     )\r\n 670:     _copy_provenance(manifest_path, output_dir)\r\n 671:     return sorted(path for path in output_dir.rglob(\"*\") if path.is_file())\r\n 672: \r\n 673: \r\n 674: def main() -> int:\r\n","exit_code":0,"status":"completed"}}
