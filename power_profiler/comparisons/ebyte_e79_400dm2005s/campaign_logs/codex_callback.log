iter(stream, fieldnames=LOSS_FIELDS)\r\n 468:         writer.writeheader()\r\n 469:         writer.writerows(rows)\r\n 470: \r\n 471:     powers = sorted({row[\"tx_power_dbm\"] for row in rows})\r\n 472:     rates = sorted({row[\"bit_rate_kbps\"] for row in rows})\r\n 473:     settings = _radio_settings(rows)\r\n 474:     frame_sizes = sorted({int(row[\"frame_bytes\"]) for row in rows})\r\n 475:     workbook = Workbook()\r\n 476:     results = workbook.active\r\n 477:     results.title = \"loss_results\"\r\n 478:     results.append(LOSS_FIELDS)\r\n 479:     for row in rows:\r\n 480:         results.append([row[field] for field in LOSS_FIELDS])\r\n 481:     _style_sheet(results)\r\n 482:     matrix = workbook.create_sheet(\"loss_matrix_percent\")\r\n 483:     matrix.append([\"TX power [dBm]\", *(setting[2] for setting in settings)])\r\n 484:     by_key = {(row[\"tx_power_dbm\"], _setting_key(row)): row for row in rows}\r\n 485:     for power in powers:\r\n 486:         matrix.append(\r\n 487:             [\r\n 488:                 power,\r\n 489:                 *(by_key[(power, setting[0])][\"frame_loss_percent\"] for setting in settings),\r\n 490:             ]\r\n 491:         )\r\n 492:     _style_sheet(matrix)\r\n 493:     workbook.save(base.with_suffix(\".xlsx\"))\r\n 494: \r\n 495:     ticks = \",\".join(_number(rate) for rate in rates)\r\n 496:     labels = \",\".join(_latex_number(rate) for rate in rates)\r\n 497:     maximum = max(row[\"frame_loss_percent\"] for row in rows)\r\n 498:     ymax = min(100, max(10, math.ceil(maximum * 1.25 / 5) * 5))\r\n 499:     xmin = min(rates) / 1.5\r\n 500:     xmax = max(rates) * 1.5\r\n 501:     lines = [\r\n 502:         r\"\\documentclass[tikz,border=6pt]{standalone}\",\r\n 503:         r\"\\usepackage[T1]{fontenc}\",\r\n 504:         r\"\\usepackage[utf8]{inputenc}\",\r\n 505:         r\"\\usepackage{pgfplots}\",\r\n 506:         r\"\\pgfplotsset{compat=1.18}\",\r\n 507:         r\"\\begin{document}\",\r\n 508:       