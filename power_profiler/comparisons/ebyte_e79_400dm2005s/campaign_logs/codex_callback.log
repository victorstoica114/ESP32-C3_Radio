t axis.south)\",\r\n 540:             rf\"  {{60 s per point; {','.join(map(str, frame_sizes))} B frames; 15 ms inter-frame gap. Shared rates may contain multiple RF profiles.}};\",\r\n 541:             r\"\\end{tikzpicture}\",\r\n 542:             r\"\\end{document}\",\r\n 543:             \"\",\r\n 544:         ]\r\n 545:     )\r\n 562: def generate(manifest_path: Path, output_dir: Path, base_name: str) -> list[Path]:\r\n 563:     manifest = _read_manifest(manifest_path)\r\n 564:     output_dir.mkdir(parents=True, exist_ok=True)\r\n 565:     tx_rows, tx_summary, tx_metadata = _collect_packet_results(manifest, \"tx\")\r\n 566:     rx_rows, rx_summary, rx_metadata = _collect_packet_results(manifest, \"rx\")\r\n 567:     repetitions = int(manifest[\"config\"][\"repetitions\"])\r\n 568:     sizes, powers, settings, rx_power, module, frame_limit = _validate_energy_matrix(\r\n 569:         tx_rows, rx_rows, repetitions\r\n 570:     )\r\n 571:     base = output_dir / base_name\r\n 572:     tx_base = base.with_name(base.name + \"_tx\")\r\n 573:     rx_base = base.with_name(base.name + \"_rx\")\r\n 574:     large_base = base.with_name(base.name + \"_payload_128_512_1024\")\r\n 575:     tx_campaign_metadata = _campaign_metadata(\r\n 576:         tx_metadata, \"tx\", sizes, powers, settings\r\n 577:     )\r\n 578:     rx_campaign_metadata = _campaign_metadata(\r\n 579:         rx_metadata, \"rx\", sizes, [rx_power], settings\r\n 580:     )\r\n 581:     write_transfer_csv(tx_base.with_suffix(\".csv\"), tx_rows)\r\n 582:     write_transfer_xlsx(\r\n 583:         tx_base.with_suffix(\".xlsx\"), tx_rows, tx_summary, tx_campaign_metadata\r\n 584:     )\r\n 585:     write_transfer_csv(rx_base.with_suffix(\".csv\"), rx_rows)\r\n 586:     write_transfer_xlsx(\r\n 587:         rx_base.with_suffix(\".xlsx\"), rx_rows, rx_summary, rx_campaign_metadata\r\n 588:     )\r\n 589:     large_rows = [row for row in tx_rows if row[\"payload_bytes\"] >= 128]\r\n 590:     large_summary = [row for