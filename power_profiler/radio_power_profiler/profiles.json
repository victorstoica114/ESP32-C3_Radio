{
  "RADIO_CC1101_V1_433": {
    "display_name": "CC1101 V1 433 MHz",
    "firmware_selection": "RADIO_CC1101_V1_433 + AT_COMMANDS",
    "baudrate": 115200,
    "setup_commands": ["AT", "AT+RESET", "AT+DEBUG=OFF", "AT+BRIDGE=ON", "AT+CS=OFF", "AT+PRE=128", "AT+SYNCERR=1", "AT+RX=OFF"],
    "post_config_commands": ["AT+RX=OFF"],
    "receiver_enable_commands": ["AT+RX=ON"],
    "payload_sizes": [8, 32, 64, 128, 512, 1024],
    "repetitions": 5,
    "cooldown_s": 0.5,
    "axes": [
      {"name": "tx_power_dbm", "label": "TX power (dBm)", "command": "AT+PWR={value}", "values": [-30, 0, 10]},
      {"name": "bit_rate_kbps", "label": "Bit rate (kbps)", "commands": {"1.2": ["AT+BR=1.2", "AT+DEV=5.2", "AT+BW=58.03"], "38.4": ["AT+BR=38.4", "AT+DEV=20", "AT+BW=101.56"], "250": ["AT+BR=250", "AT+DEV=127", "AT+BW=541.67"]}, "values": [1.2, 38.4, 250]}
    ],
    "transmit": {"mode": "burst_command", "command": "AT+TXBURST={payload_bytes},{frame_payload_bytes}", "line_overhead_bytes": 2, "max_payload_bytes": 1024, "frame_payload_bytes": 32},
    "receive": {"inter_frame_gap_ms": 15, "post_receive_s": 0.05},
    "airtime": {"kind": "fsk", "rate_axis": "bit_rate_kbps", "rate_multiplier": 1000, "overhead_bytes": 21, "ramp_s": 0.003},
    "capture": {"merge_gap_ms": 20.0, "max_after_trigger_s": 20.0},
    "notes": ["Carrier sense is disabled so each requested test produces one immediate transmission.", "Logical transfers are fragmented into physical frames of at most 32 bytes for reliable RX FIFO servicing up to 250 kbps."]
  },
